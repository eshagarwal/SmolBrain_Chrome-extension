# .env.example - Copy this to .env and add your API keys

# Featherless AI Configuration (Default provider)
FEATHERLESS_API_KEY=your_api_key_here
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# Note: This .env file is NOT used by the extension anymore.
# The extension now uses the Settings page (right-click extension icon > Options)
# to configure API settings, which are stored securely in Chrome's storage.

# This file is kept for reference only.
